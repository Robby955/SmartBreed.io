{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "my-flask-app",
          "region": "northamerica-northeast1"
        }
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}
